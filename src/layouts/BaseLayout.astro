---
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

export interface Props {
  title: string
  description: string
  canonical: string
  ogType?: string
  favicon?: string
}

const {
  title,
  description,
  canonical,
  ogType = 'website',
  favicon = '/icons/gumballs-circle.ico',
} = Astro.props
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <style>html{opacity:0}</style>
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#1973fa" />

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://ari-khan.com/assets/images/profile/gumballs.webp" />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/x-icon" href={favicon} />

    <link rel="stylesheet" href="/styles/base.css" />
    <link rel="stylesheet" href="/styles/layout.css" />
    <link rel="stylesheet" href="/styles/components.css" />
    <link rel="stylesheet" href="/styles/utilities.css" />

    <script src="https://cdn.ywxi.net/js/1.js" async></script>
    <script src="/scripts/page-transition.js" defer></script>

    <slot name="head" />
  </head>

  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
